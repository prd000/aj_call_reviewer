LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
CHAT_AGENT_MODEL=

DEEPSEEK_API_KEY=
OPENAI_API_KEY=

REV_AI_ACCESS_TOKEN=

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

VITE_APP_URL=


REDIS_URL=redis://localhost:6379/0

LLM_REQUEST_TIMEOUT=120.0
LLM_MAX_RETRIES=1

CELERY_TASK_SOFT_TIME_LIMIT=3000
CELERY_TASK_TIME_LIMIT=3300

STUCK_PENDING_THRESHOLD_SECONDS=300
STUCK_TRANSCRIBING_THRESHOLD_SECONDS=2100
STUCK_REVIEWING_THRESHOLD_SECONDS=720
REAP_INTERVAL_SECONDS=120
REVIEW_PHASE_TIMEOUT_SECONDS=240


ALLOW_STUB_PIPELINE=true

# MCP connector. PUBLIC_BASE_URL is the externally-reachable origin of THIS
# backend (e.g. https://your-app.up.railway.app) — REQUIRED for the OAuth server,
# since the advertised authorize/token/.well-known URLs are built from it.
PUBLIC_BASE_URL=
# DNS-rebinding protection is OFF unless this is set; provide a comma-separated
# Host/Origin allowlist (e.g. your Railway domain) to lock it down.
MCP_ALLOWED_HOSTS=

MISE_PYTHON_GITHUB_ATTESTATIONS=false
