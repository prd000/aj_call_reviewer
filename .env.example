# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: deepseek, openai
# LLM_MODEL overrides the provider's default model (optional)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
# CHAT_AGENT_MODEL overrides the model used by the history-chat agent only (optional).
# Defaults to LLM_MODEL → provider default. Set to a stronger model to improve
# multi-step tool-calling, or to a faster model to reduce latency.
# CHAT_AGENT_MODEL=

# API keys — only the key for the active provider is required
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ── Transcription ─────────────────────────────────────────────────────────────
REV_AI_ACCESS_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=          # service_role secret — backend only, never expose in frontend
SUPABASE_JWT_SECRET=   # Project Settings → API → JWT Settings → JWT Secret (backend only, treat as service_role-level secret)

# ── Frontend Supabase (public anon key — safe to expose) ──────────────────────
# Safe to ship in the frontend bundle BECAUSE the public tables are locked down:
# RLS is enabled in deny-all mode + anon/authenticated grants are revoked (SEC-001,
# backend/migrations/2026-06-05_enable_rls_lockdown.sql). The anon key can only reach
# Supabase Auth, not table/storage data. Does NOT need rotating.
VITE_SUPABASE_URL=     # same value as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=  # anon/public key from Supabase project settings

# ── Async processing ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM request timeouts & retries (Bug #3 fix) ───────────────────────────────
# Caps each httpx phase (connect/read/write) to prevent a stalled DeepSeek/OpenAI
# call from blocking the Celery worker indefinitely.
# 0 or negative values are clamped back to the default (httpx treats 0 = no timeout).
LLM_REQUEST_TIMEOUT=120.0      # seconds; default 120.0
LLM_MAX_RETRIES=1              # in-library retries; default 1

# ── Celery task time limits (Bug #3 fix) ──────────────────────────────────────
# Ordering invariant: 1800 (transcription ceiling) < soft < hard < 3600 (visibility_timeout)
# Soft fires SoftTimeLimitExceeded → task writes failed + no retry (loop-breaker).
# Hard SIGKILL is a last resort.
CELERY_TASK_SOFT_TIME_LIMIT=3000   # seconds; default 3000
CELERY_TASK_TIME_LIMIT=3300        # seconds; default 3300

# ── Stuck-review reaper (phase-aware) ────────────────────────────────────────
# Each in-progress status has its own stuck-detection threshold so the aggressive
# reviewing limit doesn't falsely kill slow-but-legitimate transcriptions.
# STUCK_REVIEW_THRESHOLD_SECONDS is DEPRECATED — no longer read; set the
# per-status vars below instead.
STUCK_PENDING_THRESHOLD_SECONDS=300        # seconds; default 300  (5 min)
STUCK_TRANSCRIBING_THRESHOLD_SECONDS=2100  # seconds; default 2100 (35 min; above the 1800s Rev.ai ceiling)
STUCK_REVIEWING_THRESHOLD_SECONDS=720      # seconds; default 720  (12 min)
REAP_INTERVAL_SECONDS=120                  # beat schedule interval; default 120 (2 min)

# ── Per-attempt review timeout ────────────────────────────────────────────────
# Hard wall-clock timeout around reviewer.review_call() per Celery attempt.
# On timeout the task raises TimeoutError → hits the existing auto-retry path
# (2 retries × 240s + 2 × 10s delay ≈ 12.5 min to terminal failed).
# Uses ThreadPoolExecutor (cross-platform Windows dev / Linux prod).
REVIEW_PHASE_TIMEOUT_SECONDS=240           # seconds; default 240

# ── App URL (used for invite redirect_to) ─────────────────────────────────────
VITE_APP_URL=             # e.g. https://your-app.railway.app (no trailing slash)
